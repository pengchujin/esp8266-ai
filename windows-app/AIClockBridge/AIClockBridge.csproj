<Project Sdk="Microsoft.NET.Sdk">

  <!-- Windows port of mac-app/: same tray-icon bridge (status server, screen
       mirror, quota, net speed, now-playing, petdex picker). WinForms + WinRT
       media APIs; ImageSharp is the one third-party dep, needed because
       System.Drawing cannot decode petdex's WebP spritesheets nor author
       multi-frame GIFs. EnableWindowsTargeting lets the project compile on
       non-Windows hosts too (CI / cross-checks); it only runs on Windows. -->
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows10.0.19041.0</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>disable</Nullable>
    <EnableWindowsTargeting>true</EnableWindowsTargeting>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <AssemblyName>AIClockBridge</AssemblyName>
    <RootNamespace>AIClockBridge</RootNamespace>
    <ApplicationHighDpiMode>PerMonitorV2</ApplicationHighDpiMode>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="SixLabors.ImageSharp" Version="3.1.12" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Assets\claude-logo.png" />
    <EmbeddedResource Include="Assets\codex-logo.png" />
    <EmbeddedResource Include="Assets\happy-mac.png" />
    <EmbeddedResource Include="Assets\kimi-logo.png" />
  </ItemGroup>

</Project>
